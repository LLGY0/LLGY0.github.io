---
/**
 * Astro 图标组件 - 优先使用构建时内联 SVG
 * 如果静态数据中不存在，则回退到运行时 iconify-icon (不推荐)
 */
import { getIconSvg, hasIcon } from "@utils/icons";


export interface Props {
    icon: string;
    class?: string;
    style?: string;
    size?: "xs" | "sm" | "md" | "lg" | "xl" | "2xl";
    color?: string;
    fallback?: string;
    loading?: "lazy" | "eager";
}

const {
    icon,
    class: className = "",
    style = "",
    size = "md",
    color,
    fallback = "●",
    loading = "lazy",
} = Astro.props;

// 尺寸映射
const sizeClasses = {
    xs: "text-xs",
    sm: "text-sm",
    md: "text-base",
    lg: "text-lg",
    xl: "text-xl",
    "2xl": "text-2xl",
};

const sizeClass = sizeClasses[size] || sizeClasses.md;
const colorStyle = color ? `color: ${color};` : "";
const combinedStyle = `${colorStyle}${style}`;
const combinedClass = `${sizeClass} ${className}`.trim();

const staticSvg = getIconSvg(icon);
const isStatic = hasIcon(icon);
---

{isStatic ? (
    <span
        class={`inline-flex items-center justify-center inline-icon ${combinedClass}`}
        style={combinedStyle}
        aria-hidden="true"
        set:html={staticSvg}
    />
) : (
    <span
        class={`inline-flex items-center justify-center ${combinedClass}`}
        style={combinedStyle}
    >
        <iconify-icon
            icon={icon}
            loading={loading}
        ></iconify-icon>
    </span>
)}

<style is:global>
    .inline-icon svg {
        width: 1em;
        height: 1em;
        fill: currentColor;
    }
</style>